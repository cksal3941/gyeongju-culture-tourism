{
  "version": 2,
  "builds": [
    {
      "src": "express/server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "express/views/**",
          "express/main/**",
          "express/css/**",
          "express/loginPages/**",
          "express/Project-images/**",
          "express/travel_sub1/**",
          "express/festival_sub2/**",
          "express/culture_sub3/**",
          "express/food_sub4/**",
          "express/tripHelper_sub5/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "express/server.js"
    }
  ]
}
